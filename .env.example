# ──────────────────────────────────────────────
# UOF X MCP Server — 環境變數範本
# 複製本檔案為 .env 並填入實際值
# ──────────────────────────────────────────────

# UOF X API 認證（必填）
UOFX_API_KEY=your_api_key_here
UOFX_CORP_CODE=your_corp_code

# UOF X 服務位址
UOFX_BASE_URL=https://your-uofx-domain.com

# OAuth OIDC（若需要 OAuth 流程才需填入）
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret

# 開發模式（true = 使用 API Key 直連，false = 要求 OAuth Token）
UOFX_DEV_MODE=false

# SSL 憑證驗證（true = 嚴格驗證；只有本機或自簽憑證測試環境才建議設 false）
UOFX_VERIFY_SSL=true

# SSE Server 啟動設定（避免多實例本地測試衝突，預設 127.0.0.1:8000）
MCP_SSE_HOST=127.0.0.1
MCP_SSE_PORT=8000

# Manual integration test fixtures（僅 tests/manual 使用）
UOFX_TEST_USER=test_user
UOFX_TEST_AGENT_USER=test_agent_user
UOFX_TEST_DEPT_CODE=TEST_DEPT
UOFX_TEST_FORM_CODE=TEST_FORM
UOFX_TEST_FORM_FIELD_ID=TEST_FIELD_ID
UOFX_TEST_TASK_ID=TEST_TASK_ID
MCP_SSE_TEST_TOKEN=test_token
MCP_SSE_TEST_USER=test_user
